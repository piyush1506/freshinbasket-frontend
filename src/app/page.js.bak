          </div>
          <div>
            <h4 className="font-bold text-gray-900 mb-4 text-sm uppercase">Quick Links</h4>
            <ul className="space-y-2 text-sm text-gray-500">
              <li><Link href="#" className="hover:text-green-600">About Us</Link></li>
              <li><Link href="#" className="hover:text-green-600">Contact</Link></li>
              <li><Link href="#" className="hover:text-green-600">Support</Link></li>
