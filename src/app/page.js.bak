        <div className="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
          <div>
            <div className="text-xl font-bold text-green-700 mb-4">FreshBox</div>
            <p className="text-gray-500 text-xs leading-relaxed mb-4">
