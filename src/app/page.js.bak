      name: "ripe banana",
      price: 15,
    }
  ];

  const handleIncrement = () => setQuantity((prev) => prev + 1);
  const handleDecrement = () => setQuantity((prev) => (prev > 1 ? prev - 1 : 1));

  const handlePlaceQuickOrder = async () => {
    const orderPayload = {
      items: [
        {
          name: category,
          quantity: quantity,
          price: 24.99
        }
      ]
